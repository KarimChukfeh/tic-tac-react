# V2 network configuration
# Defaults now follow the active ABI manifest in src/v2/ABIs/*.json
# Current default deployment target: Arbitrum One
VITE_NETWORK=arbitrumOne

# Optional V2 RPC override
# Preferred variable: VITE_V2_RPC_URL
# Legacy fallback still supported: VITE_RPC_URL
VITE_V2_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/yoftG-myZ5Iur7UklgbJR

# Local override example:
# VITE_NETWORK=localhost
# VITE_V2_RPC_URL=http://127.0.0.1:8545
