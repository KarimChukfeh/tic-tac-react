/**
 * DreamApp - TicTacBlock with Dream Visual Design
 * Combines the functionality of App.jsx with the visual design language from tic-tac-dream
 */

import { useState, useEffect, useRef } from 'react';
import {
  Wallet, Grid, Swords, Clock, Shield, Lock, Eye, Code, ExternalLink,
  Trophy, Play, Users, DollarSign, Zap, TrendingUp, History,
  Award, Target, CheckCircle, Info, Coins, AlertCircle
} from 'lucide-react';
import { ethers } from 'ethers';
import DUMMY_ABI from './dummyABI.json';

// Helper function
const shortenAddress = (addr) => {
  return `${addr.slice(0, 6)}...${addr.slice(-4)}`;
};

// Game status labels with emojis
const getStatusLabel = (status) => {
  switch(status) {
    case 0: return 'Waiting for Players';
    case 1: return 'Ready to Start';
    case 2: return 'Battle in Progress';
    case 3: return 'Game Complete';
    default: return 'Unknown';
  }
};

// Cell symbol
const getCellSymbol = (cell) => {
  switch(cell) {
    case 0: return '';
    case 1: return 'X';
    case 2: return 'O';
    default: return '';
  }
};

// Check for winner and winning line
const checkWinner = (board) => {
  const lines = [
    [0, 1, 2], [3, 4, 5], [6, 7, 8], // rows
    [0, 3, 6], [1, 4, 7], [2, 5, 8], // columns
    [0, 4, 8], [2, 4, 6] // diagonals
  ];

  for (const [a, b, c] of lines) {
    if (board[a] && board[a] === board[b] && board[a] === board[c]) {
      return { winner: board[a], line: [a, b, c] };
    }
  }

  if (board.every(cell => cell !== 0)) return { winner: 'draw', line: [] };
  return null;
};

// Calculate prize distribution
const calculatePrizes = (pot, isDraw) => {
  const potValue = parseFloat(pot);
  if (isDraw) {
    return {
      player1Refund: (potValue * 0.45).toFixed(6),
      player2Refund: (potValue * 0.45).toFixed(6),
      houseFee: (potValue * 0.10).toFixed(6)
    };
  } else {
    return {
      winnerPayout: (potValue * 0.95).toFixed(6),
      houseFee: (potValue * 0.05).toFixed(6)
    };
  }
};

// Particle Background Component
const ParticleBackground = () => {
  const particles = Array.from({ length: 50 }, (_, i) => ({
    id: i,
    left: Math.random() * 100,
    delay: Math.random() * 10,
    duration: 10 + Math.random() * 10,
    color: Math.random() > 0.5 ? '#00ffff' : '#ff00ff'
  }));

  return (
    <div style={{ position: 'fixed', inset: 0, pointerEvents: 'none', zIndex: 0 }}>
      {particles.map(p => (
        <div
          key={p.id}
          style={{
            position: 'absolute',
            width: '2px',
            height: '2px',
            background: p.color,
            borderRadius: '50%',
            left: `${p.left}%`,
            animation: `particle-float ${p.duration}s linear infinite`,
            animationDelay: `${p.delay}s`
          }}
        />
      ))}
    </div>
  );
};

// Glass Panel Component
const GlassPanel = ({ children, style, className = '' }) => (
  <div
    className={className}
    style={{
      background: 'rgba(255, 255, 255, 0.05)',
      backdropFilter: 'blur(10px)',
      border: '1px solid rgba(0, 255, 255, 0.3)',
      borderRadius: '15px',
      padding: '20px',
      boxShadow: '0 8px 32px 0 rgba(0, 255, 255, 0.2)',
      animation: 'float 3s ease-in-out infinite',
      ...style
    }}
  >
    {children}
  </div>
);

// Prize Distribution Component
const PrizeDistribution = ({ pot, winner, winnerAddress }) => {
  const isDraw = winner === 'draw';
  const prizes = calculatePrizes(pot, isDraw);

  return (
    <GlassPanel style={{ background: 'rgba(255, 215, 0, 0.1)', border: '2px solid rgba(255, 215, 0, 0.3)', marginTop: '20px' }}>
      <div style={{ display: 'flex', alignItems: 'center', gap: '10px', marginBottom: '20px' }}>
        <Trophy style={{ color: '#ffd700' }} size={24} />
        <h3 style={{ fontSize: '20px', fontWeight: 'bold', color: '#ffd700' }}>Prize Distribution</h3>
      </div>

      <div style={{ display: 'flex', flexDirection: 'column', gap: '12px' }}>
        {isDraw ? (
          <>
            <div style={{
              display: 'flex',
              justifyContent: 'space-between',
              alignItems: 'center',
              background: 'rgba(0, 100, 255, 0.2)',
              borderRadius: '10px',
              padding: '12px',
              border: '1px solid rgba(0, 100, 255, 0.3)'
            }}>
              <span style={{ color: 'rgba(100, 200, 255, 0.9)' }}>Each Player Refund (45%)</span>
              <span style={{ color: '#00ffff', fontWeight: 'bold', fontSize: '18px' }}>{prizes.player1Refund} ETH</span>
            </div>
            <div style={{
              display: 'flex',
              justifyContent: 'space-between',
              alignItems: 'center',
              background: 'rgba(100, 100, 100, 0.2)',
              borderRadius: '10px',
              padding: '12px'
            }}>
              <span style={{ color: 'rgba(200, 200, 200, 0.7)' }}>House Fee (10%)</span>
              <span style={{ color: 'rgba(200, 200, 200, 0.9)', fontWeight: 'bold' }}>{prizes.houseFee} ETH</span>
            </div>
          </>
        ) : (
          <>
            <div style={{
              background: 'rgba(0, 255, 136, 0.2)',
              borderRadius: '10px',
              padding: '15px',
              border: '2px solid rgba(0, 255, 136, 0.3)',
              boxShadow: '0 0 20px rgba(0, 255, 136, 0.2)'
            }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '10px' }}>
                <span style={{ color: '#00ff88' }}>Winner Payout (95%)</span>
                <span style={{ color: '#00ff88', fontWeight: 'bold', fontSize: '22px' }}>{prizes.winnerPayout} ETH</span>
              </div>
              {winnerAddress && winnerAddress !== ethers.ZeroAddress && (
                <div style={{
                  display: 'flex',
                  alignItems: 'center',
                  gap: '8px',
                  marginTop: '10px',
                  paddingTop: '10px',
                  borderTop: '1px solid rgba(0, 255, 136, 0.3)'
                }}>
                  <Award size={14} style={{ color: '#00ff88' }} />
                  <span style={{ fontSize: '12px', color: '#00ff88' }}>Winner:</span>
                  <span style={{
                    fontSize: '12px',
                    color: '#00ff88',
                    fontFamily: 'monospace',
                    background: 'rgba(0, 255, 136, 0.2)',
                    padding: '4px 8px',
                    borderRadius: '4px'
                  }}>
                    {shortenAddress(winnerAddress)}
                  </span>
                </div>
              )}
            </div>
            <div style={{
              display: 'flex',
              justifyContent: 'space-between',
              alignItems: 'center',
              background: 'rgba(100, 100, 100, 0.2)',
              borderRadius: '10px',
              padding: '12px'
            }}>
              <span style={{ color: 'rgba(200, 200, 200, 0.7)' }}>House Fee (5%)</span>
              <span style={{ color: 'rgba(200, 200, 200, 0.9)', fontWeight: 'bold' }}>{prizes.houseFee} ETH</span>
            </div>
          </>
        )}
        <div style={{
          display: 'flex',
          justifyContent: 'space-between',
          alignItems: 'center',
          background: 'rgba(255, 0, 255, 0.2)',
          borderRadius: '10px',
          padding: '12px',
          border: '2px solid rgba(255, 0, 255, 0.3)'
        }}>
          <span style={{ color: '#ff00ff', fontWeight: 'bold' }}>Total Pot</span>
          <span style={{ color: '#ff00ff', fontWeight: 'bold', fontSize: '22px' }}>{pot} ETH</span>
        </div>
      </div>
    </GlassPanel>
  );
};

// Game Progress Indicator
const GameProgress = ({ status, player1, player2, moveCount }) => {
  const steps = [
    { id: 0, label: 'Player 1 Joins', done: player1 !== ethers.ZeroAddress },
    { id: 1, label: 'Player 2 Joins', done: player2 !== ethers.ZeroAddress },
    { id: 2, label: 'Game Starts', done: status >= 2 },
    { id: 3, label: 'Players Battle', done: status === 2, active: status === 2 },
    { id: 4, label: 'Winner Declared', done: status === 3 }
  ];

  return (
    <GlassPanel style={{ marginBottom: '20px' }}>
      <div style={{ display: 'flex', alignItems: 'center', gap: '10px', marginBottom: '20px' }}>
        <Target style={{ color: '#00ffff' }} size={20} />
        <h3 style={{ fontSize: '18px', fontWeight: 'bold', color: '#00ffff' }}>Game Progress</h3>
      </div>

      <div style={{ display: 'flex', flexDirection: 'column', gap: '12px' }}>
        {steps.map((step, index) => (
          <div key={step.id} style={{ display: 'flex', alignItems: 'center', gap: '12px' }}>
            <div style={{
              width: '32px',
              height: '32px',
              borderRadius: '50%',
              display: 'flex',
              alignItems: 'center',
              justifyContent: 'center',
              fontWeight: 'bold',
              fontSize: '14px',
              background: step.done ? 'rgba(0, 255, 136, 0.3)' : step.active ? 'rgba(255, 215, 0, 0.3)' : 'rgba(100, 100, 100, 0.2)',
              color: step.done ? '#00ff88' : step.active ? '#ffd700' : 'rgba(200, 200, 200, 0.5)',
              border: `2px solid ${step.done ? '#00ff88' : step.active ? '#ffd700' : 'rgba(200, 200, 200, 0.3)'}`,
              animation: step.active ? 'pulse 2s ease-in-out infinite' : 'none'
            }}>
              {step.done ? '✓' : index + 1}
            </div>
            <div style={{ flex: 1 }}>
              <div style={{
                fontWeight: 'medium',
                color: step.done ? '#00ff88' : step.active ? '#ffd700' : 'rgba(200, 200, 200, 0.5)'
              }}>
                {step.label}
              </div>
              {step.active && (
                <div style={{ fontSize: '12px', color: '#ffd700', marginTop: '4px' }}>
                  {moveCount}/9 moves played
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </GlassPanel>
  );
};

// Last Game Result Component
const LastGameResult = ({ lastGame, account }) => {
  if (!lastGame) return null;

  const isDraw = lastGame.result === 1;
  const isWin = lastGame.result === 0;
  const timestamp = new Date(lastGame.timestamp * 1000).toLocaleString();

  const userWon = isWin && account && lastGame.winner.toLowerCase() === account.toLowerCase();
  const userLost = isWin && account && (
    (lastGame.player1.toLowerCase() === account.toLowerCase() && lastGame.winner.toLowerCase() !== account.toLowerCase()) ||
    (lastGame.player2.toLowerCase() === account.toLowerCase() && lastGame.winner.toLowerCase() !== account.toLowerCase())
  );
  const userDrew = isDraw && account && (
    lastGame.player1.toLowerCase() === account.toLowerCase() ||
    lastGame.player2.toLowerCase() === account.toLowerCase()
  );

  return (
    <GlassPanel style={{
      marginBottom: '60px',
      background: userWon
        ? 'rgba(0, 255, 136, 0.1)'
        : userLost
        ? 'rgba(255, 0, 100, 0.1)'
        : userDrew
        ? 'rgba(255, 215, 0, 0.1)'
        : 'rgba(128, 0, 255, 0.1)',
      border: `2px solid ${
        userWon ? 'rgba(0, 255, 136, 0.5)' :
        userLost ? 'rgba(255, 0, 100, 0.5)' :
        userDrew ? 'rgba(255, 215, 0, 0.5)' :
        'rgba(128, 0, 255, 0.5)'
      }`,
      animation: userWon ? 'pulse 3s ease-in-out infinite' : 'float 3s ease-in-out infinite'
    }}>
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '30px', flexWrap: 'wrap', gap: '15px' }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: '12px' }}>
          <History style={{ color: userWon ? '#00ff88' : userLost ? '#ff0064' : '#8000ff' }} size={28} />
          <div>
            <h2 style={{
              fontSize: '32px',
              fontWeight: 'bold',
              background: 'linear-gradient(90deg, #00ffff, #ff00ff)',
              WebkitBackgroundClip: 'text',
              WebkitTextFillColor: 'transparent'
            }}>Last Game Result</h2>
            {userWon && <span style={{ color: '#00ff88', fontSize: '14px', fontWeight: 'bold' }}>🎉 YOU WON!</span>}
            {userLost && <span style={{ color: '#ff0064', fontSize: '14px', fontWeight: 'bold' }}>💔 You Lost</span>}
            {userDrew && <span style={{ color: '#ffd700', fontSize: '14px', fontWeight: 'bold' }}>🤝 You Drew</span>}
          </div>
        </div>
        <div style={{
          background: 'rgba(128, 0, 255, 0.2)',
          border: '1px solid rgba(128, 0, 255, 0.5)',
          padding: '8px 16px',
          borderRadius: '20px'
        }}>
          <span style={{ color: '#8000ff', fontSize: '14px', fontWeight: 'bold' }}>Game #{lastGame.gameId}</span>
        </div>
      </div>

      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '30px' }}>
        {/* Game Outcome */}
        <div style={{
          borderRadius: '15px',
          padding: '30px',
          border: `2px solid ${
            isDraw ? 'rgba(255, 215, 0, 0.5)' :
            userWon ? 'rgba(0, 255, 136, 0.5)' :
            'rgba(0, 255, 255, 0.5)'
          }`,
          background: `${
            isDraw ? 'rgba(255, 215, 0, 0.1)' :
            userWon ? 'rgba(0, 255, 136, 0.15)' :
            'rgba(0, 255, 255, 0.1)'
          }`,
          boxShadow: userWon ? '0 0 30px rgba(0, 255, 136, 0.3)' : 'none'
        }}>
          <div style={{ textAlign: 'center', display: 'flex', flexDirection: 'column', gap: '15px' }}>
            <div style={{ fontSize: '64px' }}>
              {isDraw ? '🤝' : userWon ? '🎉' : '🏆'}
            </div>
            <div style={{
              fontSize: '32px',
              fontWeight: 'bold',
              color: isDraw ? '#ffd700' : userWon ? '#00ff88' : '#00ffff'
            }}>
              {isDraw ? 'DRAW' : userWon ? 'YOU WON!' : 'WINNER'}
            </div>
            {isWin && (
              <div style={{
                background: 'rgba(0, 0, 0, 0.5)',
                borderRadius: '10px',
                padding: '12px'
              }}>
                <div style={{ fontSize: '12px', color: 'rgba(200, 200, 200, 0.7)', marginBottom: '6px' }}>Winner Address</div>
                <div style={{ fontFamily: 'monospace', fontSize: '16px', color: '#fff' }}>
                  {shortenAddress(lastGame.winner)}
                </div>
                {userWon && (
                  <div style={{
                    marginTop: '8px',
                    fontSize: '10px',
                    background: 'rgba(0, 255, 136, 0.2)',
                    color: '#00ff88',
                    padding: '4px 8px',
                    borderRadius: '6px',
                    display: 'inline-flex',
                    alignItems: 'center',
                    gap: '4px',
                    border: '1px solid rgba(0, 255, 136, 0.3)'
                  }}>
                    <CheckCircle size={12} />
                    This is you!
                  </div>
                )}
              </div>
            )}
            {userWon && (
              <div style={{
                background: 'rgba(0, 255, 136, 0.2)',
                borderRadius: '10px',
                padding: '12px',
                border: '1px solid rgba(0, 255, 136, 0.3)'
              }}>
                <div style={{ color: '#00ff88', fontWeight: 'bold', fontSize: '16px' }}>Prize Won: 95% of pot</div>
              </div>
            )}
            <div style={{ fontSize: '12px', color: 'rgba(200, 200, 200, 0.7)' }}>
              {timestamp}
            </div>
          </div>
        </div>

        {/* Players */}
        <div style={{ display: 'flex', flexDirection: 'column', gap: '15px' }}>
          <div style={{ fontSize: '18px', fontWeight: 'bold', color: '#8000ff', marginBottom: '10px' }}>Players</div>

          {/* Player 1 */}
          <div style={{
            padding: '15px',
            borderRadius: '10px',
            border: `2px solid ${
              isWin && lastGame.winner.toLowerCase() === lastGame.player1.toLowerCase()
                ? 'rgba(0, 255, 136, 0.5)'
                : account && lastGame.player1.toLowerCase() === account.toLowerCase()
                ? 'rgba(0, 255, 255, 0.5)'
                : 'rgba(0, 255, 255, 0.3)'
            }`,
            background: `${
              isWin && lastGame.winner.toLowerCase() === lastGame.player1.toLowerCase()
                ? 'rgba(0, 255, 136, 0.2)'
                : account && lastGame.player1.toLowerCase() === account.toLowerCase()
                ? 'rgba(0, 255, 255, 0.15)'
                : 'rgba(0, 255, 255, 0.1)'
            }`,
            boxShadow: isWin && lastGame.winner.toLowerCase() === lastGame.player1.toLowerCase() ? '0 0 20px rgba(0, 255, 136, 0.3)' : 'none'
          }}>
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '10px' }}>
              <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
                <div style={{
                  width: '32px',
                  height: '32px',
                  borderRadius: '50%',
                  background: 'rgba(0, 255, 255, 0.3)',
                  display: 'flex',
                  alignItems: 'center',
                  justifyContent: 'center',
                  color: '#00ffff',
                  fontWeight: 'bold',
                  border: '2px solid #00ffff'
                }}>X</div>
                <span style={{ fontSize: '14px', fontWeight: 'bold', color: '#00ffff' }}>Player 1</span>
              </div>
              {isWin && lastGame.winner.toLowerCase() === lastGame.player1.toLowerCase() && (
                <Trophy style={{ color: '#00ff88' }} size={20} />
              )}
            </div>
            <div style={{
              fontFamily: 'monospace',
              fontSize: '12px',
              color: '#fff',
              background: 'rgba(0, 0, 0, 0.5)',
              padding: '8px',
              borderRadius: '6px'
            }}>
              {shortenAddress(lastGame.player1)}
            </div>
            {account && lastGame.player1.toLowerCase() === account.toLowerCase() && (
              <div style={{
                marginTop: '8px',
                fontSize: '10px',
                background: 'rgba(0, 100, 255, 0.2)',
                color: '#0088ff',
                padding: '4px 8px',
                borderRadius: '4px',
                display: 'inline-flex',
                alignItems: 'center',
                gap: '4px',
                border: '1px solid rgba(0, 100, 255, 0.3)'
              }}>
                <CheckCircle size={12} />
                This is you!
              </div>
            )}
          </div>

          {/* Player 2 */}
          <div style={{
            padding: '15px',
            borderRadius: '10px',
            border: `2px solid ${
              isWin && lastGame.winner.toLowerCase() === lastGame.player2.toLowerCase()
                ? 'rgba(0, 255, 136, 0.5)'
                : account && lastGame.player2.toLowerCase() === account.toLowerCase()
                ? 'rgba(255, 0, 255, 0.5)'
                : 'rgba(255, 0, 255, 0.3)'
            }`,
            background: `${
              isWin && lastGame.winner.toLowerCase() === lastGame.player2.toLowerCase()
                ? 'rgba(0, 255, 136, 0.2)'
                : account && lastGame.player2.toLowerCase() === account.toLowerCase()
                ? 'rgba(255, 0, 255, 0.15)'
                : 'rgba(255, 0, 255, 0.1)'
            }`,
            boxShadow: isWin && lastGame.winner.toLowerCase() === lastGame.player2.toLowerCase() ? '0 0 20px rgba(0, 255, 136, 0.3)' : 'none'
          }}>
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '10px' }}>
              <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
                <div style={{
                  width: '32px',
                  height: '32px',
                  borderRadius: '50%',
                  background: 'rgba(255, 0, 255, 0.3)',
                  display: 'flex',
                  alignItems: 'center',
                  justifyContent: 'center',
                  color: '#ff00ff',
                  fontWeight: 'bold',
                  border: '2px solid #ff00ff'
                }}>O</div>
                <span style={{ fontSize: '14px', fontWeight: 'bold', color: '#ff00ff' }}>Player 2</span>
              </div>
              {isWin && lastGame.winner.toLowerCase() === lastGame.player2.toLowerCase() && (
                <Trophy style={{ color: '#00ff88' }} size={20} />
              )}
            </div>
            <div style={{
              fontFamily: 'monospace',
              fontSize: '12px',
              color: '#fff',
              background: 'rgba(0, 0, 0, 0.5)',
              padding: '8px',
              borderRadius: '6px'
            }}>
              {shortenAddress(lastGame.player2)}
            </div>
            {account && lastGame.player2.toLowerCase() === account.toLowerCase() && (
              <div style={{
                marginTop: '8px',
                fontSize: '10px',
                background: 'rgba(0, 100, 255, 0.2)',
                color: '#0088ff',
                padding: '4px 8px',
                borderRadius: '4px',
                display: 'inline-flex',
                alignItems: 'center',
                gap: '4px',
                border: '1px solid rgba(0, 100, 255, 0.3)'
              }}>
                <CheckCircle size={12} />
                This is you!
              </div>
            )}
          </div>

          {/* Game Stats */}
          <div style={{
            background: 'rgba(128, 0, 255, 0.1)',
            borderRadius: '10px',
            padding: '15px',
            border: '1px solid rgba(128, 0, 255, 0.3)',
            marginTop: '10px'
          }}>
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
              <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
                <TrendingUp style={{ color: '#8000ff' }} size={16} />
                <span style={{ fontSize: '14px', color: '#8000ff' }}>Outcome</span>
              </div>
              <span style={{ color: '#fff', fontWeight: 'bold', fontSize: '14px' }}>
                {isDraw ? 'Draw - Both Refunded 45%' : 'Winner Takes 95%'}
              </span>
            </div>
          </div>
        </div>
      </div>
    </GlassPanel>
  );
};

// Active Game Display Component with Dream Design
const ActiveGameDisplay = ({ game, account, onMove, onStartGame, loading, gameLog, refreshProgress }) => {
  const isPlayer1 = account && game.player1.toLowerCase() === account.toLowerCase();
  const isPlayer2 = account && game.player2.toLowerCase() === account.toLowerCase();
  const isParticipant = isPlayer1 || isPlayer2;
  const isMyTurn = account && game.currentTurn?.toLowerCase() === account.toLowerCase();

  const winnerResult = checkWinner(game.board);
  const winningLine = winnerResult?.line || [];

  const gameOver = game.status === 3;
  const contractWinner = game.winner;
  const isDraw = gameOver && contractWinner === ethers.ZeroAddress;
  const hasWinner = gameOver && contractWinner !== ethers.ZeroAddress;
  const isWinner = hasWinner && account && contractWinner.toLowerCase() === account.toLowerCase();
  const isLoser = hasWinner && isParticipant && contractWinner.toLowerCase() !== account.toLowerCase();

  const player1Symbol = 'X';
  const player2Symbol = 'O';
  const mySymbol = isPlayer1 ? player1Symbol : isPlayer2 ? player2Symbol : null;
  const moveCount = game.board.filter(c => c !== 0).length;

  return (
    <GlassPanel style={{ marginBottom: '40px', maxWidth: '1400px', margin: '0 auto' }}>
      {/* Header */}
      <div style={{ textAlign: 'center', marginBottom: '30px' }}>
        <h2 style={{
          fontSize: '32px',
          fontWeight: 'bold',
          background: 'linear-gradient(90deg, #00ffff, #ff00ff)',
          WebkitBackgroundClip: 'text',
          WebkitTextFillColor: 'transparent',
          marginBottom: '10px',
          textShadow: '0 0 20px rgba(0, 255, 255, 0.5)'
        }}>
          ⚔️ Battle Arena - Game #{game.id}
        </h2>
        <div style={{
          display: 'inline-block',
          padding: '10px 20px',
          borderRadius: '20px',
          background: game.status === 2 ? 'rgba(0, 255, 255, 0.2)' : 'rgba(255, 0, 255, 0.2)',
          border: `2px solid ${game.status === 2 ? '#00ffff' : '#ff00ff'}`,
          color: game.status === 2 ? '#00ffff' : '#ff00ff',
          fontWeight: 'bold'
        }}>
          {getStatusLabel(game.status)}
        </div>
      </div>

      {/* Main Layout - Three Columns */}
      <div style={{ display: 'grid', gridTemplateColumns: '300px 1fr 300px', gap: '30px', alignItems: 'start' }}>
        {/* Left Column - Progress & Prize */}
        <div>
          <GameProgress
            status={game.status}
            player1={game.player1}
            player2={game.player2}
            moveCount={moveCount}
          />

          {gameOver && (
            <PrizeDistribution
              pot={game.pot}
              winner={isDraw ? 'draw' : 'winner'}
              winnerAddress={contractWinner}
            />
          )}
        </div>

        {/* Center Column - Game Board */}
        <div>

      {/* Game Board */}
      <div style={{ textAlign: 'center', marginBottom: '30px' }}>
        <div style={{
          background: 'rgba(0, 0, 0, 0.5)',
          padding: '20px',
          borderRadius: '20px',
          border: '2px solid rgba(0, 255, 255, 0.3)',
          boxShadow: '0 0 50px rgba(0, 255, 255, 0.3), inset 0 0 50px rgba(0, 255, 255, 0.1)',
          display: 'inline-block'
        }}>
          <div style={{
            display: 'grid',
            gridTemplateColumns: 'repeat(3, 120px)',
            gridTemplateRows: 'repeat(3, 120px)',
            gap: '10px'
          }}>
            {game.board.map((cell, idx) => {
              const isWinningCell = winningLine.includes(idx);
              const cellSymbol = getCellSymbol(cell);
              return (
                <button
                  key={idx}
                  onClick={() => isMyTurn && game.status === 2 && cell === 0 ? onMove(idx) : null}
                  disabled={loading || !isMyTurn || game.status !== 2 || cell !== 0}
                  style={{
                    background: isWinningCell
                      ? 'linear-gradient(135deg, rgba(255, 215, 0, 0.4), rgba(255, 165, 0, 0.4))'
                      : isMyTurn && game.status === 2 && cell === 0
                      ? 'rgba(255, 255, 255, 0.05)'
                      : cell === 1
                      ? 'rgba(0, 255, 255, 0.2)'
                      : cell === 2
                      ? 'rgba(255, 0, 255, 0.2)'
                      : 'rgba(255, 255, 255, 0.05)',
                    border: isWinningCell
                      ? '2px solid #ffd700'
                      : `2px solid ${cell === 1 ? '#00ffff' : cell === 2 ? '#ff00ff' : 'rgba(0, 255, 255, 0.3)'}`,
                    borderRadius: '15px',
                    display: 'flex',
                    justifyContent: 'center',
                    alignItems: 'center',
                    fontSize: '60px',
                    fontWeight: 'bold',
                    cursor: isMyTurn && game.status === 2 && cell === 0 ? 'pointer' : 'not-allowed',
                    transition: 'all 0.3s ease',
                    color: cell === 1 ? '#00ffff' : '#ff00ff',
                    textShadow: cellSymbol ? `0 0 20px ${cell === 1 ? '#00ffff' : '#ff00ff'}, 0 0 40px ${cell === 1 ? '#00ffff' : '#ff00ff'}` : 'none',
                    animation: cellSymbol ? (cell === 1 ? 'glow-cyan 1.5s ease-in-out infinite' : 'glow-magenta 1.5s ease-in-out infinite') : 'none',
                    boxShadow: isWinningCell ? '0 0 30px rgba(255, 215, 0, 0.8)' : 'none'
                  }}
                  onMouseEnter={(e) => {
                    if (isMyTurn && game.status === 2 && cell === 0) {
                      e.target.style.background = 'rgba(0, 255, 255, 0.1)';
                      e.target.style.borderColor = 'rgba(0, 255, 255, 0.6)';
                      e.target.style.transform = 'scale(1.05)';
                    }
                  }}
                  onMouseLeave={(e) => {
                    if (isMyTurn && game.status === 2 && cell === 0) {
                      e.target.style.background = 'rgba(255, 255, 255, 0.05)';
                      e.target.style.borderColor = 'rgba(0, 255, 255, 0.3)';
                      e.target.style.transform = 'scale(1)';
                    }
                  }}
                >
                  {cellSymbol}
                </button>
              );
            })}
          </div>
        </div>
      </div>

      {/* Start Game Button */}
      {game.status === 1 && isParticipant && (
        <div style={{ textAlign: 'center', marginTop: '30px' }}>
          <button
            onClick={onStartGame}
            disabled={loading}
            style={{
              background: 'linear-gradient(90deg, #00ffff, #ff00ff)',
              border: 'none',
              borderRadius: '25px',
              padding: '12px 30px',
              color: '#fff',
              fontWeight: 'bold',
              fontSize: '16px',
              cursor: loading ? 'not-allowed' : 'pointer',
              boxShadow: '0 0 20px rgba(0, 255, 255, 0.5)',
              transition: 'all 0.3s ease',
              opacity: loading ? 0.5 : 1
            }}
            onMouseEnter={(e) => !loading && (e.target.style.transform = 'scale(1.05)', e.target.style.boxShadow = '0 0 30px rgba(0, 255, 255, 0.8)')}
            onMouseLeave={(e) => !loading && (e.target.style.transform = 'scale(1)', e.target.style.boxShadow = '0 0 20px rgba(0, 255, 255, 0.5)')}
          >
            <Zap size={20} style={{ display: 'inline', marginRight: '8px' }} />
            {loading ? 'Initiating Coin Flip...' : 'Start Game (Coin Flip)'}
          </button>
        </div>
      )}

      {/* Turn Indicator */}
      {!gameOver && game.status === 2 && (
        <div style={{
          textAlign: 'center',
          marginTop: '30px',
          padding: '20px',
          borderRadius: '15px',
          background: isMyTurn ? 'rgba(0, 255, 136, 0.2)' : 'rgba(0, 255, 255, 0.1)',
          border: `2px solid ${isMyTurn ? '#00ff88' : 'rgba(0, 255, 255, 0.3)'}`,
          color: isMyTurn ? '#00ff88' : '#00ffff',
          fontWeight: 'bold',
          fontSize: '20px',
          animation: isMyTurn ? 'pulse 2s ease-in-out infinite' : 'none'
        }}>
          {isMyTurn ? (
            <div>
              <div style={{ fontSize: '32px' }}>🎯 YOUR TURN</div>
              <div style={{ fontSize: '14px', opacity: 0.8, marginTop: '8px' }}>You are playing as {mySymbol}</div>
            </div>
          ) : isParticipant ? (
            <div>⏳ Opponent's Turn</div>
          ) : (
            <div>👁️ Spectating</div>
          )}
        </div>
      )}

      {/* Winner Display */}
      {gameOver && (
        <div style={{
          textAlign: 'center',
          marginTop: '30px',
          padding: '30px',
          borderRadius: '15px',
          background: isDraw
            ? 'rgba(128, 128, 128, 0.2)'
            : isWinner
            ? 'rgba(0, 255, 136, 0.2)'
            : isLoser
            ? 'rgba(255, 0, 100, 0.2)'
            : 'rgba(255, 215, 0, 0.2)',
          border: `2px solid ${isDraw ? '#808080' : isWinner ? '#00ff88' : isLoser ? '#ff0064' : '#ffd700'}`,
          color: isDraw ? '#808080' : isWinner ? '#00ff88' : isLoser ? '#ff0064' : '#ffd700',
          fontWeight: 'bold',
          fontSize: '32px',
          animation: isWinner ? 'pulse 2s ease-in-out infinite' : 'none'
        }}>
          {isDraw ? (
            <>
              <div style={{ fontSize: '64px' }}>🤝</div>
              <div>DRAW GAME!</div>
              <div style={{ fontSize: '14px', opacity: 0.8, marginTop: '8px' }}>Both players receive 45% refund</div>
            </>
          ) : isWinner ? (
            <>
              <div style={{ fontSize: '64px' }}>🎉</div>
              <div>VICTORY!</div>
              <div style={{ fontSize: '14px', opacity: 0.8, marginTop: '8px' }}>You won 95% of the pot!</div>
              <div style={{ fontSize: '12px', marginTop: '8px', fontFamily: 'monospace' }}>
                {shortenAddress(contractWinner)}
              </div>
            </>
          ) : isLoser ? (
            <>
              <div style={{ fontSize: '64px' }}>💔</div>
              <div>DEFEAT</div>
              <div style={{ fontSize: '14px', opacity: 0.8, marginTop: '8px' }}>Better luck next time</div>
              <div style={{ fontSize: '12px', marginTop: '8px' }}>Winner: {shortenAddress(contractWinner)}</div>
            </>
          ) : (
            <>
              <div style={{ fontSize: '64px' }}>🏆</div>
              <div>GAME OVER!</div>
              <div style={{ fontSize: '14px', opacity: 0.8, marginTop: '8px' }}>
                Winner: {contractWinner.toLowerCase() === game.player1.toLowerCase() ? `${player1Symbol}` : `${player2Symbol}`}
              </div>
              <div style={{ fontSize: '12px', marginTop: '8px', fontFamily: 'monospace' }}>
                {shortenAddress(contractWinner)}
              </div>
            </>
          )}
        </div>
      )}
        </div>

        {/* Right Column - Players, Stats & Activity Log */}
        <div>

      {/* Players Info */}
      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '20px', marginTop: '30px' }}>
        {/* Player 1 */}
        <div style={{
          padding: '15px',
          borderRadius: '10px',
          background: game.currentTurn?.toLowerCase() === game.player1.toLowerCase() && game.status === 2
            ? 'rgba(0, 255, 255, 0.2)'
            : 'rgba(0, 255, 255, 0.1)',
          border: '2px solid rgba(0, 255, 255, 0.3)',
          animation: game.currentTurn?.toLowerCase() === game.player1.toLowerCase() && game.status === 2 ? 'pulse 2s ease-in-out infinite' : 'none'
        }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: '10px', marginBottom: '10px' }}>
            <div style={{
              width: '32px',
              height: '32px',
              borderRadius: '50%',
              background: 'rgba(0, 255, 255, 0.3)',
              display: 'flex',
              alignItems: 'center',
              justifyContent: 'center',
              color: '#00ffff',
              fontWeight: 'bold',
              border: '2px solid #00ffff'
            }}>X</div>
            <span style={{ fontWeight: 'bold', color: '#00ffff' }}>Player 1</span>
          </div>
          <div style={{
            fontFamily: 'monospace',
            fontSize: '12px',
            color: '#fff',
            background: 'rgba(0, 0, 0, 0.5)',
            padding: '8px',
            borderRadius: '5px'
          }}>
            {shortenAddress(game.player1)}
          </div>
          {isPlayer1 && (
            <div style={{
              marginTop: '8px',
              fontSize: '10px',
              background: 'rgba(0, 255, 136, 0.2)',
              color: '#00ff88',
              padding: '4px 8px',
              borderRadius: '4px',
              display: 'inline-flex',
              alignItems: 'center',
              gap: '4px',
              border: '1px solid rgba(0, 255, 136, 0.3)'
            }}>
              <CheckCircle size={12} />
              This is you!
            </div>
          )}
        </div>

        {/* Player 2 */}
        {game.player2 === '0x0000000000000000000000000000000000000000' ? (
          <div style={{
            padding: '15px',
            borderRadius: '10px',
            background: 'rgba(255, 0, 255, 0.05)',
            border: '2px dashed rgba(255, 0, 255, 0.3)',
            animation: 'pulse 2s ease-in-out infinite'
          }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: '10px', marginBottom: '10px' }}>
              <div style={{
                width: '32px',
                height: '32px',
                borderRadius: '50%',
                background: 'rgba(255, 0, 255, 0.3)',
                display: 'flex',
                alignItems: 'center',
                justifyContent: 'center',
                color: '#ff00ff',
                fontWeight: 'bold',
                border: '2px dashed #ff00ff'
              }}>O</div>
              <span style={{ fontWeight: 'bold', color: '#ff00ff' }}>Player 2</span>
            </div>
            <div style={{ fontSize: '14px', color: '#ff00ff', fontStyle: 'italic', display: 'flex', alignItems: 'center', gap: '8px' }}>
              <Clock size={14} />
              Waiting for opponent...
            </div>
          </div>
        ) : (
          <div style={{
            padding: '15px',
            borderRadius: '10px',
            background: game.currentTurn?.toLowerCase() === game.player2.toLowerCase() && game.status === 2
              ? 'rgba(255, 0, 255, 0.2)'
              : 'rgba(255, 0, 255, 0.1)',
            border: '2px solid rgba(255, 0, 255, 0.3)',
            animation: game.currentTurn?.toLowerCase() === game.player2.toLowerCase() && game.status === 2 ? 'pulse 2s ease-in-out infinite' : 'none'
          }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: '10px', marginBottom: '10px' }}>
              <div style={{
                width: '32px',
                height: '32px',
                borderRadius: '50%',
                background: 'rgba(255, 0, 255, 0.3)',
                display: 'flex',
                alignItems: 'center',
                justifyContent: 'center',
                color: '#ff00ff',
                fontWeight: 'bold',
                border: '2px solid #ff00ff'
              }}>O</div>
              <span style={{ fontWeight: 'bold', color: '#ff00ff' }}>Player 2</span>
            </div>
            <div style={{
              fontFamily: 'monospace',
              fontSize: '12px',
              color: '#fff',
              background: 'rgba(0, 0, 0, 0.5)',
              padding: '8px',
              borderRadius: '5px'
            }}>
              {shortenAddress(game.player2)}
            </div>
            {isPlayer2 && (
              <div style={{
                marginTop: '8px',
                fontSize: '10px',
                background: 'rgba(0, 255, 136, 0.2)',
                color: '#00ff88',
                padding: '4px 8px',
                borderRadius: '4px',
                display: 'inline-flex',
                alignItems: 'center',
                gap: '4px',
                border: '1px solid rgba(0, 255, 136, 0.3)'
              }}>
                <CheckCircle size={12} />
                This is you!
              </div>
            )}
          </div>
        )}
      </div>

      {/* Game Stats */}
      <div style={{ marginTop: '30px' }}>
        <div style={{
          display: 'flex',
          justifyContent: 'space-between',
          alignItems: 'center',
          background: 'rgba(255, 215, 0, 0.1)',
          borderRadius: '10px',
          padding: '15px',
          border: '1px solid rgba(255, 215, 0, 0.3)'
        }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
            <Coins size={20} style={{ color: '#ffd700' }} />
            <span style={{ color: '#fff', fontWeight: 'medium' }}>Prize Pot</span>
          </div>
          <span style={{ color: '#ffd700', fontWeight: 'bold', fontSize: '20px' }}>{game.pot} ETH</span>
        </div>
      </div>
    </GlassPanel>
  );
};

export default function DreamApp() {
  const CONTRACT_ADDRESS = "0x7fc74A84a41Ac0E4872fB94EB3d6A8998884Ec9d";
  const ETHERSCAN_URL = `https://arbiscan.io/address/${CONTRACT_ADDRESS}`;

  // Wallet & Contract State
  const [account, setAccount] = useState(null);
  const [contract, setContract] = useState(null);

  // Game State
  const [game, setGame] = useState(null);
  const [loading, setLoading] = useState(false);
  const [initialLoading, setInitialLoading] = useState(true);
  const [entryFee, setEntryFee] = useState('0');

  const prevGameState = useRef(null);

  // Switch to Arbitrum One Network
  const switchToArbitrum = async () => {
    try {
      await window.ethereum.request({
        method: 'wallet_switchEthereumChain',
        params: [{ chainId: '0xa4b1' }],
      });
    } catch (switchError) {
      if (switchError.code === 4902) {
        try {
          await window.ethereum.request({
            method: 'wallet_addEthereumChain',
            params: [
              {
                chainId: '0xa4b1',
                chainName: 'Arbitrum One',
                nativeCurrency: {
                  name: 'Ethereum',
                  symbol: 'ETH',
                  decimals: 18,
                },
                rpcUrls: ['https://arb1.arbitrum.io/rpc'],
                blockExplorerUrls: ['https://arbiscan.io'],
              },
            ],
          });
          alert('✅ Arbitrum One network added! Please connect your wallet again.');
        } catch (addError) {
          console.error('Error adding Arbitrum One network:', addError);
          alert('Failed to add Arbitrum One network. Please add it manually in MetaMask.');
        }
      } else {
        console.error('Error switching network:', switchError);
        alert('Failed to switch network: ' + switchError.message);
      }
    }
  };

  // Connect Wallet
  const connectWallet = async () => {
    try {
      if (!window.ethereum) {
        alert('Please install MetaMask to use this dApp!');
        return;
      }

      setLoading(true);

      const accounts = await window.ethereum.request({
        method: 'eth_requestAccounts'
      });

      const web3Provider = new ethers.BrowserProvider(window.ethereum);
      const network = await web3Provider.getNetwork();

      console.log('Connected to network:', network);

      if (network.chainId !== 42161n) {
        const shouldSwitch = window.confirm(
          `⚠️ Wrong Network Detected\n\n` +
          `You're connected to: ${network.name || 'Unknown'} (Chain ID: ${network.chainId})\n` +
          `Expected: Arbitrum One (Chain ID: 42161)\n\n` +
          `Click OK to automatically switch networks, or Cancel to stay on current network.`
        );

        if (shouldSwitch) {
          await switchToArbitrum();
          window.location.reload();
          return;
        }
      }

      const web3Signer = await web3Provider.getSigner();

      const contractInstance = new ethers.Contract(
        CONTRACT_ADDRESS,
        DUMMY_ABI,
        web3Signer
      );

      console.log('Contract initialized at:', CONTRACT_ADDRESS);

      setAccount(accounts[0]);
      setContract(contractInstance);

      await loadContractData(contractInstance, false);
      setLoading(false);
    } catch (error) {
      console.error('Error connecting wallet:', error);

      let errorMessage = 'Failed to connect wallet.\n\n';

      if (error.message.includes('user rejected')) {
        errorMessage += 'You rejected the connection request.';
      } else if (error.code === 'NETWORK_ERROR') {
        errorMessage += 'Network error. Are you connected to Arbitrum One?\n\nSwitch to Arbitrum One in MetaMask.';
      } else {
        errorMessage += error.message;
      }

      alert(errorMessage);
      setLoading(false);
    }
  };

  // Load contract data
  const loadContractData = async (contractInstance, isInitialLoad = false) => {
    try {
      const provider = contractInstance.runner.provider;
      const contractAddress = await contractInstance.getAddress();
      const code = await provider.getCode(contractAddress);

      if (code === '0x' || code === '0x0') {
        console.error('❌ No bytecode found at address:', contractAddress);
        throw new Error('Contract not deployed at this address');
      }

      const fee = await contractInstance.ENTRY_FEE();
      setEntryFee(ethers.formatEther(fee));

      const player1 = await contractInstance.player1();
      const player2 = await contractInstance.player2();
      const currentTurn = await contractInstance.currentTurn();
      const winner = await contractInstance.winner();
      const pot = await contractInstance.pot();
      const status = await contractInstance.status();

      const board = [];
      for (let i = 0; i < 9; i++) {
        const cell = await contractInstance.board(i);
        board.push(Number(cell));
      }

      const gameData = {
        id: '1',
        player1,
        player2,
        winner,
        pot: ethers.formatEther(pot),
        status: Number(status),
        board,
        currentTurn
      };

      prevGameState.current = gameData;
      setGame(gameData);

      if (isInitialLoad) {
        setInitialLoading(false);
      }
    } catch (error) {
      console.error('Error loading contract data:', error);

      if (isInitialLoad) {
        setInitialLoading(false);
      }

      if (account) {
        alert('Error loading game data: ' + error.message);
      }
    }
  };

  // Join the game
  const joinGame = async () => {
    if (!contract) return;

    try {
      setLoading(true);
      const tx = await contract.joinGame({
        value: ethers.parseEther(entryFee)
      });
      await tx.wait();

      await loadContractData(contract);
      alert('Joined game successfully!');
      setLoading(false);
    } catch (error) {
      console.error('Error joining game:', error);
      alert('Failed to join game. ' + error.message);
      setLoading(false);
    }
  };

  // Start the game
  const startGame = async () => {
    if (!contract) return;

    try {
      setLoading(true);
      const tx = await contract.startGame();
      await tx.wait();

      await loadContractData(contract);
      alert('Game started! A coin flip determined who goes first.');
      setLoading(false);
    } catch (error) {
      console.error('Error starting game:', error);
      alert('Failed to start game. ' + error.message);
      setLoading(false);
    }
  };

  // Make a move
  const makeMove = async (cellIndex) => {
    if (!contract) return;

    try {
      setLoading(true);
      const tx = await contract.makeMove(cellIndex);
      await tx.wait();

      await loadContractData(contract);
      setLoading(false);
    } catch (error) {
      console.error('Error making move:', error);
      alert('Failed to make move. ' + error.message);
      setLoading(false);
    }
  };

  // Initialize contract in read-only mode
  useEffect(() => {
    const initReadOnlyContract = async () => {
      try {
        const provider = new ethers.JsonRpcProvider('https://arb1.arbitrum.io/rpc');

        const readOnlyContract = new ethers.Contract(
          CONTRACT_ADDRESS,
          DUMMY_ABI,
          provider
        );

        setContract(readOnlyContract);
        await loadContractData(readOnlyContract, true);
      } catch (error) {
        console.error('Error initializing read-only contract:', error);
        setInitialLoading(false);
      }
    };

    if (!contract) {
      initReadOnlyContract();
    }
  }, []);

  // Listen for account changes
  useEffect(() => {
    if (window.ethereum) {
      window.ethereum.on('accountsChanged', (accounts) => {
        if (accounts.length === 0) {
          setAccount(null);
          const initReadOnlyContract = async () => {
            const provider = new ethers.JsonRpcProvider('https://arb1.arbitrum.io/rpc');
            const readOnlyContract = new ethers.Contract(CONTRACT_ADDRESS, DUMMY_ABI, provider);
            setContract(readOnlyContract);
            await loadContractData(readOnlyContract);
          };
          initReadOnlyContract();
        } else {
          connectWallet();
        }
      });

      window.ethereum.on('chainChanged', () => {
        window.location.reload();
      });
    }
  }, []);

  // Set up event listeners and auto-refresh
  useEffect(() => {
    if (!contract) return;

    const onEvent = () => {
      console.log('Contract event received');
      loadContractData(contract);
    };

    contract.on('PlayerJoined', onEvent);
    contract.on('GameStarted', onEvent);
    contract.on('MoveMade', onEvent);
    contract.on('GameEnded', onEvent);

    const refreshInterval = setInterval(() => {
      loadContractData(contract);
    }, 5000);

    return () => {
      contract.off('PlayerJoined', onEvent);
      contract.off('GameStarted', onEvent);
      contract.off('MoveMade', onEvent);
      contract.off('GameEnded', onEvent);
      clearInterval(refreshInterval);
    };
  }, [contract]);

  // Loading screen
  if (initialLoading) {
    return (
      <div style={{
        minHeight: '100vh',
        background: 'linear-gradient(135deg, #0a0015 0%, #1a0030 50%, #0f001a 100%)',
        color: '#fff',
        display: 'flex',
        justifyContent: 'center',
        alignItems: 'center',
        flexDirection: 'column'
      }}>
        <ParticleBackground />
        <div style={{
          textAlign: 'center',
          zIndex: 10,
          position: 'relative'
        }}>
          <Grid className="animate-pulse" size={64} style={{ color: '#00ffff', marginBottom: '20px' }} />
          <h2 style={{
            fontSize: '32px',
            fontWeight: 'bold',
            background: 'linear-gradient(90deg, #00ffff, #ff00ff)',
            WebkitBackgroundClip: 'text',
            WebkitTextFillColor: 'transparent',
            marginBottom: '10px'
          }}>Loading Game Data</h2>
          <p style={{ color: 'rgba(0, 255, 255, 0.7)' }}>Connecting to Arbitrum blockchain...</p>
        </div>
      </div>
    );
  }

  return (
    <div style={{
      minHeight: '100vh',
      background: 'linear-gradient(135deg, #0a0015 0%, #1a0030 50%, #0f001a 100%)',
      color: '#fff',
      position: 'relative',
      overflow: 'hidden'
    }}>
      <ParticleBackground />

      {/* Trust Banner */}
      <div style={{
        background: 'rgba(0, 100, 200, 0.2)',
        borderBottom: '1px solid rgba(0, 255, 255, 0.3)',
        backdropFilter: 'blur(10px)',
        position: 'relative',
        zIndex: 10
      }}>
        <div style={{
          maxWidth: '1200px',
          margin: '0 auto',
          padding: '15px 30px',
          display: 'flex',
          justifyContent: 'space-between',
          alignItems: 'center',
          flexWrap: 'wrap',
          gap: '20px'
        }}>
          <div style={{ display: 'flex', gap: '30px', alignItems: 'center' }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
              <Shield size={16} style={{ color: '#00ffff' }} />
              <span style={{ color: '#00ffff', fontWeight: 'medium', fontSize: '14px' }}>100% On-Chain Games</span>
            </div>
            <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
              <Lock size={16} style={{ color: '#00ffff' }} />
              <span style={{ color: '#00ffff', fontWeight: 'medium', fontSize: '14px' }}>Immutable Rules</span>
            </div>
          </div>
          <a
            href={ETHERSCAN_URL}
            target="_blank"
            rel="noopener noreferrer"
            style={{
              display: 'flex',
              alignItems: 'center',
              gap: '8px',
              color: '#00ffff',
              textDecoration: 'none',
              fontSize: '12px',
              transition: 'color 0.3s ease'
            }}
          >
            <Code size={16} />
            <span style={{ fontFamily: 'monospace' }}>{shortenAddress(CONTRACT_ADDRESS)}</span>
            <ExternalLink size={14} />
          </a>
        </div>
      </div>

      {/* Main Content */}
      <div style={{
        maxWidth: '1200px',
        margin: '0 auto',
        padding: '60px 30px',
        position: 'relative',
        zIndex: 10
      }}>
        {/* Hero Section */}
        <div style={{ textAlign: 'center', marginBottom: '80px' }}>
          <div style={{ position: 'relative', display: 'inline-block', marginBottom: '40px' }}>
            <Grid size={80} style={{ color: '#00ffff', animation: 'float 3s ease-in-out infinite' }} />
          </div>

          <h1 style={{
            fontSize: '64px',
            fontWeight: 'bold',
            background: 'linear-gradient(90deg, #00ffff, #ff00ff)',
            WebkitBackgroundClip: 'text',
            WebkitTextFillColor: 'transparent',
            marginBottom: '20px',
            textShadow: '0 0 40px rgba(0, 255, 255, 0.5)'
          }}>
            Tic-Tac-Dream Protocol
          </h1>
          <p style={{
            fontSize: '24px',
            color: '#00ffff',
            marginBottom: '30px',
            textShadow: '0 0 20px rgba(0, 255, 255, 0.3)'
          }}>
            Provably Fair • Zero Trust • 100% On-Chain
          </p>

          {/* Connect Wallet CTA */}
          {!account ? (
            <button
              onClick={connectWallet}
              disabled={loading}
              style={{
                display: 'inline-flex',
                alignItems: 'center',
                gap: '12px',
                background: 'linear-gradient(90deg, #00ffff, #ff00ff)',
                border: 'none',
                borderRadius: '30px',
                padding: '20px 40px',
                fontWeight: 'bold',
                fontSize: '24px',
                cursor: loading ? 'not-allowed' : 'pointer',
                boxShadow: '0 0 30px rgba(0, 255, 255, 0.5)',
                transition: 'all 0.3s ease',
                opacity: loading ? 0.5 : 1,
                color: '#fff'
              }}
              onMouseEnter={(e) => !loading && (e.target.style.transform = 'scale(1.05)', e.target.style.boxShadow = '0 0 40px rgba(0, 255, 255, 0.8)')}
              onMouseLeave={(e) => !loading && (e.target.style.transform = 'scale(1)', e.target.style.boxShadow = '0 0 30px rgba(0, 255, 255, 0.5)')}
            >
              <Wallet size={28} />
              {loading ? 'Connecting...' : 'Connect Wallet to Enter'}
            </button>
          ) : (
            <div style={{
              display: 'inline-flex',
              alignItems: 'center',
              gap: '15px',
              background: 'rgba(0, 255, 136, 0.2)',
              border: '2px solid rgba(0, 255, 136, 0.5)',
              padding: '15px 30px',
              borderRadius: '30px',
              boxShadow: '0 0 20px rgba(0, 255, 136, 0.3)'
            }}>
              <div style={{
                width: '12px',
                height: '12px',
                background: '#00ff88',
                borderRadius: '50%',
                animation: 'pulse 2s ease-in-out infinite',
                boxShadow: '0 0 10px #00ff88'
              }} />
              <span style={{ fontFamily: 'monospace', fontSize: '18px', color: '#00ff88' }}>{shortenAddress(account)}</span>
            </div>
          )}
        </div>

        {/* Active Game Section */}
        {game && (
          <div style={{ marginBottom: '60px' }}>
            <ActiveGameDisplay
              game={game}
              account={account}
              onMove={makeMove}
              onStartGame={startGame}
              loading={loading}
            />
          </div>
        )}

        {/* Join Game Section */}
        {account && contract && game && (
          <GlassPanel style={{ marginBottom: '60px' }}>
            <h2 style={{
              fontSize: '36px',
              fontWeight: 'bold',
              background: 'linear-gradient(90deg, #00ffff, #ff00ff)',
              WebkitBackgroundClip: 'text',
              WebkitTextFillColor: 'transparent',
              marginBottom: '30px',
              textAlign: 'center'
            }}>
              <Play size={36} style={{ display: 'inline', marginRight: '12px', color: '#00ffff' }} />
              Game Actions
            </h2>

            {(game.status === 0 || game.status === 1) && game.player1 === '0x0000000000000000000000000000000000000000' && (
              <div style={{ textAlign: 'center' }}>
                <button
                  onClick={joinGame}
                  disabled={loading}
                  style={{
                    background: 'linear-gradient(90deg, #00ff88, #00ffff)',
                    border: 'none',
                    borderRadius: '20px',
                    padding: '15px 40px',
                    fontWeight: 'bold',
                    fontSize: '20px',
                    cursor: loading ? 'not-allowed' : 'pointer',
                    boxShadow: '0 0 20px rgba(0, 255, 136, 0.5)',
                    transition: 'all 0.3s ease',
                    opacity: loading ? 0.5 : 1,
                    color: '#000'
                  }}
                  onMouseEnter={(e) => !loading && (e.target.style.transform = 'scale(1.05)')}
                  onMouseLeave={(e) => !loading && (e.target.style.transform = 'scale(1)')}
                >
                  {loading ? 'Joining...' : `Join as Player 1 (${entryFee} ETH)`}
                </button>
                <p style={{ color: '#00ffff', marginTop: '15px' }}>Be the first player to join the arena!</p>
              </div>
            )}

            {(game.status === 0 || game.status === 1) && game.player1 !== '0x0000000000000000000000000000000000000000' && game.player2 === '0x0000000000000000000000000000000000000000' && game.player1.toLowerCase() !== account.toLowerCase() && (
              <div style={{ textAlign: 'center' }}>
                <button
                  onClick={joinGame}
                  disabled={loading}
                  style={{
                    background: 'linear-gradient(90deg, #ff00ff, #ff0080)',
                    border: 'none',
                    borderRadius: '20px',
                    padding: '15px 40px',
                    fontWeight: 'bold',
                    fontSize: '20px',
                    cursor: loading ? 'not-allowed' : 'pointer',
                    boxShadow: '0 0 20px rgba(255, 0, 255, 0.5)',
                    transition: 'all 0.3s ease',
                    opacity: loading ? 0.5 : 1,
                    color: '#fff'
                  }}
                  onMouseEnter={(e) => !loading && (e.target.style.transform = 'scale(1.05)')}
                  onMouseLeave={(e) => !loading && (e.target.style.transform = 'scale(1)')}
                >
                  {loading ? 'Joining...' : `Join as Player 2 (${entryFee} ETH)`}
                </button>
                <p style={{ color: '#ff00ff', marginTop: '15px' }}>Challenge the waiting player!</p>
              </div>
            )}

            {(game.status === 0 || game.status === 1) && game.player1.toLowerCase() === account.toLowerCase() && game.player2 === '0x0000000000000000000000000000000000000000' && (
              <div style={{
                textAlign: 'center',
                padding: '30px',
                background: 'rgba(0, 255, 255, 0.1)',
                borderRadius: '15px',
                border: '2px solid rgba(0, 255, 255, 0.3)'
              }}>
                <p style={{ color: '#00ffff' }}>You're in the arena! Waiting for opponent to join...</p>
              </div>
            )}
          </GlassPanel>
        )}

        {/* Not Connected State */}
        {!account && game && (
          <GlassPanel>
            <h2 style={{
              fontSize: '36px',
              fontWeight: 'bold',
              background: 'linear-gradient(90deg, #ff00ff, #ff0080)',
              WebkitBackgroundClip: 'text',
              WebkitTextFillColor: 'transparent',
              marginBottom: '20px',
              textAlign: 'center'
            }}>
              <Wallet size={36} style={{ display: 'inline', marginRight: '12px', color: '#ff00ff' }} />
              Ready to Play?
            </h2>
            <div style={{
              textAlign: 'center',
              padding: '40px',
              background: 'rgba(255, 0, 255, 0.1)',
              borderRadius: '15px',
              border: '2px solid rgba(255, 0, 255, 0.3)'
            }}>
              <p style={{ fontSize: '24px', color: '#ff00ff', marginBottom: '20px', fontWeight: 'bold' }}>
                Connect Your Wallet to Join the Game
              </p>
              <p style={{ fontSize: '18px', color: '#ff00ff', marginBottom: '30px', opacity: 0.8 }}>
                You're currently spectating. Connect to compete for real stakes!
              </p>
              <button
                onClick={connectWallet}
                disabled={loading}
                style={{
                  display: 'inline-flex',
                  alignItems: 'center',
                  gap: '12px',
                  background: 'linear-gradient(90deg, #ff00ff, #ff0080)',
                  border: 'none',
                  borderRadius: '30px',
                  padding: '20px 40px',
                  fontWeight: 'bold',
                  fontSize: '24px',
                  cursor: loading ? 'not-allowed' : 'pointer',
                  boxShadow: '0 0 30px rgba(255, 0, 255, 0.5)',
                  transition: 'all 0.3s ease',
                  opacity: loading ? 0.5 : 1,
                  color: '#fff'
                }}
                onMouseEnter={(e) => !loading && (e.target.style.transform = 'scale(1.05)')}
                onMouseLeave={(e) => !loading && (e.target.style.transform = 'scale(1)')}
              >
                <Wallet size={28} />
                {loading ? 'Connecting...' : 'Connect Wallet to Play'}
              </button>
            </div>
          </GlassPanel>
        )}
      </div>

      {/* Footer */}
      <div style={{
        borderTop: '1px solid rgba(255, 255, 255, 0.1)',
        position: 'relative',
        zIndex: 10
      }}>
        <div style={{
          maxWidth: '1200px',
          margin: '0 auto',
          padding: '30px',
          textAlign: 'center',
          fontSize: '14px',
          color: 'rgba(0, 255, 255, 0.7)'
        }}>
          <p style={{ fontWeight: 'bold', fontSize: '18px', marginBottom: '10px', color: '#00ffff' }}>
            Tic-Tac-Dream Protocol
          </p>
          <p>Built on Ethereum. Runs forever. No servers required.</p>
          <p style={{ marginTop: '10px' }}>Smart contracts are immutable and transparent. Always verify before interacting.</p>
        </div>
      </div>

      {/* CSS Animations */}
      <style>{`
        @keyframes float {
          0%, 100% { transform: translateY(0px); }
          50% { transform: translateY(-10px); }
        }

        @keyframes pulse {
          0%, 100% { opacity: 1; }
          50% { opacity: 0.5; }
        }

        @keyframes glow-cyan {
          0%, 100% { filter: brightness(1); }
          50% { filter: brightness(1.5); }
        }

        @keyframes glow-magenta {
          0%, 100% { filter: brightness(1); }
          50% { filter: brightness(1.5); }
        }

        @keyframes particle-float {
          0% {
            transform: translateY(100vh) translateX(0);
            opacity: 0;
          }
          10% {
            opacity: 1;
          }
          90% {
            opacity: 1;
          }
          100% {
            transform: translateY(-100vh) translateX(100px);
            opacity: 0;
          }
        }
      `}</style>
    </div>
  );
}
